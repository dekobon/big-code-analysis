{
  // markdownlint-cli2 configuration.
  //
  // MD024 `siblings_only` accommodates the Keep a Changelog convention
  // of repeating `### Added` / `### Changed` etc. across version
  // sections. MD013 line-length is widened to 120 to match the project's
  // editorconfig; tables and code blocks are exempt because their layout
  // is dictated by content, not rewrap-friendly prose.
  "config": {
    "MD013": {
      "line_length": 120,
      "tables": false,
      "code_blocks": false
    },
    "MD024": {
      "siblings_only": true
    }
  },
  "ignores": [
    "target/**",
    "node_modules/**",
    ".claude/**",
    "tests/repositories/**",
    "big-code-analysis-book/book/**"
  ]
}
