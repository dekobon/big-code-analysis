{
  "include": ["python", "tests", "examples"],
  "exclude": ["**/__pycache__", "**/target", "**/.venv"],
  "pythonVersion": "3.12",
  "typeCheckingMode": "strict",
  "reportMissingTypeStubs": "error",
  "reportMissingImports": "error",
  "useLibraryCodeForTypes": true,
  "venvPath": ".",
  "venv": ".venv"
}
